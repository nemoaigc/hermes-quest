# Hermes Quest Dashboard — Environment Variables

# Backend URL for Vite dev server proxy
VITE_BACKEND_URL=http://localhost:8420

# API key for backend authentication (set in server/.env too)
QUEST_API_KEY=your_api_key_here

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_user_id_here
